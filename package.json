{
  "name": "idle-lineage-snake-god",
  "version": "3.4.35",
  "private": true,
  "description": "放置天堂－蛇神降世 Windows 桌面版",
  "main": "desktop/main.js",
  "scripts": {
    "desktop": "electron .",
    "build:win": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "25.1.8"
  },
  "build": {
    "appId": "tw.cheng.idle-lineage.snake-god",
    "productName": "放置天堂-蛇神降世",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "assets/**/*",
      "!assets/app-icon-transparent.png",
      "css/**/*",
      "js/**/*",
      "public/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "target": "portable",
      "artifactName": "放置天堂-蛇神降世-${version}.exe"
    }
  }
}
